// Villi — Foundation data model
// Relational, normalized schema. PostgreSQL enforces FKs + constraints
// (Consistency); multi-step writes run inside transactions (Atomicity,
// Isolation); committed rows survive crashes (Durability).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Auth & Identity ─────────────────────────────

enum Role {
  USER
  ADMIN
}

enum OAuthProvider {
  GOOGLE
  GITHUB
  FACEBOOK
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  // Null for accounts created purely through OAuth.
  passwordHash    String?
  firstName       String
  lastName        String
  role            Role     @default(USER)
  isEmailVerified Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  twoFactor       TwoFactorSecret?
  oauthAccounts   OAuthAccount[]
  refreshTokens   RefreshToken[]
  passwordResets  PasswordResetToken[]
  reviews         Review[]

  @@index([email])
}

// Stores the TOTP shared secret. Separated from User so the secret can be
// fetched/audited independently and a 2FA enrollment can be pending.
model TwoFactorSecret {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  // TOTP secret (base32). Pending until the user verifies the first code.
  secret        String
  enabled       Boolean   @default(false)
  // Hashed single-use recovery codes (JSON array of argon2 hashes).
  recoveryCodes String[]  @default([])
  createdAt     DateTime  @default(now())
  confirmedAt   DateTime?
}

model OAuthAccount {
  id                String        @id @default(uuid())
  provider          OAuthProvider
  providerAccountId String
  userId            String
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime      @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Refresh tokens are single-use and rotated. We persist only a hash.
// `familyId` groups all tokens descended from one login so that detecting a
// replayed (already-rotated) token lets us revoke the whole family.
model RefreshToken {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash    String    @unique
  familyId     String
  expiresAt    DateTime
  revokedAt    DateTime?
  // Points to the token that replaced this one (set on rotation).
  replacedById String?
  userAgent    String?
  ip           String?
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([familyId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ───────────────────────────── Catalog ─────────────────────────────

model Category {
  id          String     @id @default(uuid())
  name        String
  slug        String     @unique
  description String?
  parentId    String?
  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]
  createdAt   DateTime   @default(now())

  @@index([parentId])
  @@index([slug])
}

model Brand {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  logoUrl     String?
  products    Product[]
  createdAt   DateTime  @default(now())

  @@index([slug])
}

model Product {
  id            String   @id @default(uuid())
  name          String
  slug          String   @unique
  description   String
  // Decimal avoids floating-point money errors.
  price         Decimal  @db.Decimal(12, 2)
  currency      String   @default("EUR")
  stockQuantity Int      @default(0)

  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  brandId       String
  brand         Brand    @relation(fields: [brandId], references: [id])

  // Dimensions stored canonically in metric base units; imperial is derived
  // by the API layer so we never persist redundant/inconsistent values.
  weightGrams   Int?
  lengthMm      Int?
  widthMm       Int?
  heightMm      Int?

  // Denormalized rating aggregates kept in sync transactionally with Reviews,
  // so faceted/sort queries avoid expensive joins on hot paths.
  averageRating Float    @default(0)
  ratingCount   Int      @default(0)

  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  images        ProductImage[]
  attributes    ProductAttribute[]
  reviews       Review[]

  @@index([categoryId])
  @@index([brandId])
  @@index([price])
  @@index([averageRating])
  @@index([name])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  position  Int     @default(0)
  isPrimary Boolean @default(false)

  @@index([productId])
}

// Generic key/value attributes power faceted search (e.g. condition=Very Good,
// size=M, colour=Deep Forest, authenticity=Verified). For pre-loved apparel
// these capture the per-item details buyers filter on. Indexed on (name, value).
model ProductAttribute {
  id        String  @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  name      String
  value     String

  @@unique([productId, name])
  @@index([name, value])
}

model Review {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int
  title     String?
  body      String?
  createdAt DateTime @default(now())

  @@unique([productId, userId])
  @@index([productId])
}
