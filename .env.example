# ─────────────────────────────────────────────────────────────
# Villi — environment configuration (12-factor)
# Copy to `.env` and fill in. Docker Compose reads this file.
# ─────────────────────────────────────────────────────────────

# --- Core ---
NODE_ENV=development
API_PORT=3001
# Host ports published by docker compose. Change these if 3001/5173 are already
# in use on your machine (e.g. API_HOST_PORT=3100, WEB_HOST_PORT=5273).
API_HOST_PORT=3001
WEB_HOST_PORT=5173
# Unified gateway (nginx): web + API on one origin — use for ngrok / remote demos.
PROXY_HOST_PORT=8080
# ── Recommended: unified proxy on :8080 (start with ./start.sh) ──
# Browse http://localhost:8080 — web and API share one origin (OAuth + cookies).
API_PUBLIC_URL=http://localhost:8080
WEB_PUBLIC_URL=http://localhost:8080
VITE_API_BASE_URL=/api/v1
GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth/google/callback
GITHUB_CALLBACK_URL=http://localhost:8080/api/v1/auth/oauth/github/callback

# ── Alternative: split ports (web :5173, API :3001) — uncomment and comment block above ──
# API_PUBLIC_URL=http://localhost:3001
# WEB_PUBLIC_URL=http://localhost:5173
# VITE_API_BASE_URL=http://localhost:3001/api/v1
# GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/google/callback
# GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/auth/oauth/github/callback

# --- PostgreSQL ---
POSTGRES_USER=villi
POSTGRES_PASSWORD=villi_dev_password
POSTGRES_DB=villi
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Composed connection string consumed by Prisma
DATABASE_URL=postgresql://villi:villi_dev_password@postgres:5432/villi?schema=public

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# --- JWT ---
# Use long random strings in production (e.g. `openssl rand -hex 48`)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
# Access token lifetime (15-60m per spec). Refresh: 3-7d.
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# --- Google reCAPTCHA (v2/v3) ---
# Leave RECAPTCHA_SECRET empty to disable captcha enforcement in dev.
RECAPTCHA_SECRET=
RECAPTCHA_MIN_SCORE=0.5

# --- OAuth: Google ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Callback URL is set in the "Recommended" block above.

# --- OAuth: GitHub ---
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Callback URL is set in the "Recommended" block above.

# --- Mail (SMTP) ---
# Leave SMTP_HOST empty to log emails to console (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="Villi <no-reply@villi.test>"

# --- 2FA ---
TWO_FACTOR_APP_NAME=Villi

# --- Rate limiting (per IP) ---
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# --- Frontend build-time vars (Vite, prefixed VITE_) — rebuild `web` after changes ---
# VITE_API_BASE_URL is set in the "Recommended" block above.
VITE_RECAPTCHA_SITE_KEY=
VITE_GOOGLE_OAUTH_ENABLED=false
VITE_GITHUB_OAUTH_ENABLED=false
VITE_FACEBOOK_OAUTH_ENABLED=false
