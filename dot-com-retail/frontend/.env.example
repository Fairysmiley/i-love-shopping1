# Frontend Environment Variables
# Copy this file to .env and configure with your actual values

# Django backend API URL
VITE_API_URL=http://localhost:8000

# Google reCAPTCHA site key (public key - same as RECAPTCHA_PUBLIC_KEY in backend .env)
VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# Google OAuth Client ID (same as GOOGLE_CLIENT_ID in backend .env)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.googleusercontent.com