# Secret key for django. Also used for jwt
SECRET_KEY=django-insecure-change-this-to-a-random-long-string-for-security # Replace with a secure key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,host.docker.internal  # host.docker.internal needed for Stripe CLI webhook forwarding

# Database (PostgreSQL)
# If using docker these values should match docker-compose.yml
DATABASE_NAME=ecommerce_db
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Google reCAPTCHA V2 - get from https://www.google.com/recaptcha/admin/
# Make sure to have V2 tickbox thing and not V3
# You might need to add localhost and 127.0.0.1 to the domain list
RECAPTCHA_PUBLIC_KEY=your-recaptcha-site-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-secret-key

# Email Settings for password reset

# Can also use the console backend thing for testing.
# with that there is no need to set these values.
# To enable that, in ecommerce/settings.py
# uncomment the line:
# EMAIL_BACKEND = 'django.core.mail.backends.console.EmailBackend'
# and comment the line:
# EMAIL_BACKEND = 'django.core.mail.backends.smtp.EmailBackend'

# If you want to use Gmail SMTP server:
# Gmail setup: You need to have "2-Step Verification" on your google account i think
# Then go to https://myaccount.google.com/apppasswords 
# And create new app password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
# Sender email (your Gmail)
EMAIL_HOST_USER=your-email@gmail.com
# The generated app password
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL='Dot-Com Retail <noreply@yourdomain.com>'

# For Google OAuth
# Get from https://console.developers.google.com/auth/clients
# Create new Web Application Client and add the frontend URL to authorized javascript origins
# Might need to include the port aswell
GOOGLE_CLIENT_ID=your-google-client-id.googleusercontent.com

# Frontend URL for password reset links
FRONTEND_URL=http://localhost:5173

# Payments (Stripe sandbox)
# Get API keys from Stripe dashboard (test mode)
# https://dashboard.stripe.com/
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# Webhook signing secret for verifying Stripe webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Message queue (RabbitMQ) - used for payment/order processing in background
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
